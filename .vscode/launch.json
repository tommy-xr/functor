    "version": "0.2.0",
    "configurations": [
        {
            "name": "Node.js",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/out/src/main.js",
            "runtimeArgs": ["--experimental-modules"],
            "args": [],
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Rust",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "build"
                ]
            },
            "program": "${cargo:program}",
            "args": [],
            "cwd": "${workspaceFolder}"
        }
    ]
}