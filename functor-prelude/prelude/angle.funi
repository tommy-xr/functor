//! Branded angles used by cameras, rotations, and spot lights.
//!
//! Angle-taking APIs require an `Angle.t`, preventing radians and degrees from
//! being mixed accidentally. Construct one with `Angle.degrees` or
//! `Angle.radians`.

/// An opaque angle value.
type t

/// Construct an angle from degrees.
let degrees : (float) => t
/// Construct an angle from radians.
let radians : (float) => t
